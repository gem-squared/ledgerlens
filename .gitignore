# LedgerLens — .gitignore

# === Confidential data — local ONLY, never push ===
# Canonical location for all secrets (.env, DEPLOY.md with VPS IP/SSH, etc.).
# The root `.env` is a symlink → Confidential-data/.env; both are ignored.
Confidential-data/

# === Session-level / TPMN governance — NEVER include in public repo ===
.claude/
.gem-squared/
CLAUDE.md

# === Docs — local-only working notes, integration docs, etc. ===
# Strategy / demo-script / judge-guide / legal notices live in Docs/ but
# stay off the public repo (per david@gineers.ai, 2026-05-25). The
# public pitch deck lives at pitch/ at the repo root.
Docs/

# === Generated build artifacts ===
# pitch/ at root is the source of truth; web-export mirrors it here so the
# Next.js static export bundles the deck into the Go binary at /pitch/.
apps/web/public/pitch/

# === OS / editor ===
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# === Secrets ===
.env
.env.*
!.env.example
!apps/web/.env.local.example
*.pem
*.key
credentials.json

# === Go ===
# Compiled binaries (cmd/ledgerlens output, etc.)
/ledgerlens
/ledgerlens-*
/bin/
/dist/
# Test artifacts
*.test
*.out
coverage.txt
# Go workspace (uncomment if using go.work)
# go.work
# go.work.sum
# Vendored deps (we do not vendor)
vendor/

# === Node / Next.js ===
node_modules/
.next/
out/
.turbo/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# === LedgerLens runtime artifacts (kept structure, ignore content) ===
# Receipts and bundles produced at runtime — large + frequently mutated
artifacts/fetch_receipts/*
!artifacts/fetch_receipts/.gitkeep
artifacts/audit_bundles/*
!artifacts/audit_bundles/.gitkeep
# Demo cases are committed (seeded scenarios for REPLAY mode)
# storage runtime data
storage/local.db
storage/*.db
storage/*.db-journal
storage/*.db-wal
storage/*.db-shm

# === Generated TS types (regenerate via `make schemas`) ===
packages/contracts-ts/types.ts

# === Embedded web static — build artifacts from `make web-export` ===
# Only .gitkeep is committed. `make web-export` populates the rest before
# `go build`. Dev builds without that step show an inline dev-banner page
# (cmd/ledgerlens/static_embed.go devBannerHandler).
cmd/ledgerlens/web_static/*
!cmd/ledgerlens/web_static/.gitkeep

# Next.js export staging
apps/web/out/

# Built binaries
bin/
