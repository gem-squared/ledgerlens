# LedgerLens — Go backend environment
# Copy this file to .env (which is gitignored) and fill in your own values.

# === Server ===
PORT=8082
LEDGERLENS_BIND=127.0.0.1
LEDGERLENS_LOG_LEVEL=info

# === Storage ===
LEDGERLENS_DB_PATH=storage/local.db

# === GEM² Audit Gate (REQUIRED for Unit 3+) ===
# Provisioned by David — owner of gem2-tpmn-checker.fly.dev
GEM2_API_KEY=
GEM2_TPMN_CHECKER_BASE_URL=https://gem2-tpmn-checker.fly.dev

# === LLM provider key for the audit gate (one is enough — gate is LLM-agnostic) ===
# Passed per-request to gem2-tpmn-checker; never stored long-lived on the server.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === Bright Data (REQUIRED for Unit 2+) ===
BRIGHTDATA_API_TOKEN=
# Optional — for the MCP server (defaults to npx invocation)
BRIGHTDATA_MCP_COMMAND=npx
BRIGHTDATA_MCP_ARGS=-y,@brightdata/mcp-server

# === x402 SIMULATION MODE (hackathon lock) ===
# DO NOT add Coinbase / CDP / Base Sepolia / private-key envs here.
# The hackathon repo ships only SimulatedSettler.
# Post-hackathon, a CoinbaseX402Settler can be wired behind the Settler interface.
LEDGERLENS_SETTLEMENT_MODE=simulation
